---
interface Props {
  pageTitle: string;
  pageContent: string;
}
const { pageTitle, pageContent } = Astro.props;
---

<section class="ask-ai no-print" data-page-title={pageTitle} data-page-content={pageContent}>
  <details>
    <summary>discuss this passage</summary>

    <div class="ask-body">
      <p class="muted ask-keymsg" data-keymsg style="display: none;">
        Set your <a href="/settings/">Anthropic API key</a> to enable.
      </p>

      <form data-ask-form>
        <textarea
          data-ask-input
          rows="3"
          placeholder="ask about this passage — Hebrew/Greek, cross-references, practice distillation, comparison across frames…"
          required
        ></textarea>
        <div class="ask-actions">
          <button type="submit" data-ask-submit>ask</button>
          <button type="button" data-ask-stop style="display: none;">stop</button>
          <span class="muted ask-hint">⌘/Ctrl + ↵ to send</span>
        </div>
      </form>

      <div class="ask-output prose" data-ask-output data-pagefind-ignore></div>
    </div>
  </details>
</section>

<script>
  import { loadSettings } from "../lib/storage";
  import { streamMessage } from "../lib/anthropic";
  import { SYSTEM_PROMPT, buildUserMessage } from "../lib/system-prompt";

  function renderMarkdown(text: string): string {
    const esc = (s: string) =>
      s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
    const inline = (s: string) =>
      s
        .replace(/`([^`]+)`/g, "<code>$1</code>")
        .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
        .replace(/\*([^*]+)\*/g, "<em>$1</em>");

    const lines = text.split("\n");
    let html = "";
    let inList = false;
    let inBlockquote = false;
    const closeBlocks = () => {
      if (inList) { html += "</ul>"; inList = false; }
      if (inBlockquote) { html += "</blockquote>"; inBlockquote = false; }
    };
    for (const raw of lines) {
      const line = esc(raw);
      if (/^#{1,4}\s+/.test(line)) {
        closeBlocks();
        const lvl = (line.match(/^(#+)/) as RegExpMatchArray)[1].length;
        const text = line.replace(/^#+\s+/, "");
        const h = Math.min(lvl + 2, 4);
        html += `<h${h}>${inline(text)}</h${h}>`;
      } else if (/^>\s?/.test(line)) {
        if (!inBlockquote) { html += "<blockquote>"; inBlockquote = true; }
        html += `<p>${inline(line.replace(/^>\s?/, ""))}</p>`;
      } else if (/^[-*]\s+/.test(line)) {
        if (!inList) { html += "<ul>"; inList = true; }
        html += `<li>${inline(line.replace(/^[-*]\s+/, ""))}</li>`;
      } else if (line.trim() === "") {
        closeBlocks();
      } else {
        closeBlocks();
        html += `<p>${inline(line)}</p>`;
      }
    }
    closeBlocks();
    return html;
  }

  function init(section: HTMLElement) {
    const pageTitle = section.dataset.pageTitle ?? "";
    const pageContent = section.dataset.pageContent ?? "";
    const form = section.querySelector<HTMLFormElement>("[data-ask-form]")!;
    const input = section.querySelector<HTMLTextAreaElement>("[data-ask-input]")!;
    const submit = section.querySelector<HTMLButtonElement>("[data-ask-submit]")!;
    const stop = section.querySelector<HTMLButtonElement>("[data-ask-stop]")!;
    const output = section.querySelector<HTMLDivElement>("[data-ask-output]")!;
    const keymsg = section.querySelector<HTMLParagraphElement>("[data-keymsg]")!;

    function refreshKeyMsg() {
      const s = loadSettings();
      const has = s.apiKey.trim().length > 0;
      keymsg.style.display = has ? "none" : "block";
      submit.disabled = !has;
    }
    refreshKeyMsg();
    window.addEventListener("storage", refreshKeyMsg);

    let controller: AbortController | null = null;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const settings = loadSettings();
      if (!settings.apiKey.trim()) { refreshKeyMsg(); return; }
      const question = input.value.trim();
      if (!question) return;

      output.textContent = "";
      output.scrollIntoView({ behavior: "smooth", block: "nearest" });
      submit.style.display = "none";
      stop.style.display = "inline-block";
      controller = new AbortController();

      let accumulated = "";

      await streamMessage({
        apiKey: settings.apiKey,
        model: settings.model,
        system: SYSTEM_PROMPT,
        userMessage: buildUserMessage(pageTitle, pageContent, question),
        onText: (chunk) => {
          accumulated += chunk;
          output.innerHTML = renderMarkdown(accumulated);
        },
        onError: (msg) => {
          output.innerHTML = `<p class="muted"><strong>Error:</strong> ${msg}</p>`;
        },
        onDone: () => {
          submit.style.display = "inline-block";
          stop.style.display = "none";
          controller = null;
        },
        abortSignal: controller.signal,
      });
    });

    stop.addEventListener("click", () => {
      if (controller) controller.abort();
    });

    input.addEventListener("keydown", (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === "Enter") {
        form.requestSubmit();
      }
    });
  }

  document.querySelectorAll<HTMLElement>(".ask-ai").forEach(init);
</script>

<style>
  .ask-ai {
    max-width: 68ch;
    margin: 3rem auto 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-rule);
  }
  .ask-ai summary {
    cursor: pointer;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-muted);
    padding: 0.25rem 0;
    user-select: none;
  }
  .ask-ai summary:hover { color: var(--color-fg); }
  .ask-body { margin-top: 1rem; }
  .ask-keymsg { margin-bottom: 0.75rem; font-size: 0.9rem; }
  textarea[data-ask-input] {
    width: 100%;
    padding: 0.6rem 0.75rem;
    background: var(--color-card);
    color: var(--color-fg);
    border: 1px solid var(--color-rule);
    border-radius: 4px;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    line-height: 1.5;
    resize: vertical;
  }
  textarea[data-ask-input]:focus {
    outline: none;
    border-color: var(--color-accent);
  }
  .ask-actions {
    margin-top: 0.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }
  .ask-actions button {
    background: var(--color-card);
    color: var(--color-fg);
    border: 1px solid var(--color-rule);
    border-radius: 4px;
    padding: 0.45rem 1rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    cursor: pointer;
  }
  .ask-actions button:hover:not(:disabled) {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .ask-actions button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .ask-hint {
    font-family: var(--font-sans);
    font-size: 0.8rem;
  }
  .ask-output {
    margin-top: 1.5rem;
    padding-top: 0.5rem;
  }
  .ask-output:empty { display: none; }
</style>
