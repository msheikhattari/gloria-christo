---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const fullTitle = title === "gloria-christo" ? title : `${title} · gloria-christo`;
const defaultDesc =
  "Scripture study skeleton. KJV concordance, operational practices, close-reading analyses. Public-domain texts. MIT-licensed. Self-host welcome.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description ?? defaultDesc} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0e0f10" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fbf9f4" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <title>{fullTitle}</title>
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
